# flyhypo secrets — copy to `.env` and fill in. NEVER commit your real .env.

# neuPrint token. Log in at https://neuprint.janelia.org with a Google account,
# then click your name (top-right) → "Account" and copy the auth token.
# (Default dataset hemibrain:v1.2.1 needs no special access.)
NEUPRINT_APPLICATION_CREDENTIALS=

# Google Gemini API key for the synthesis step. Get one at
# https://aistudio.google.com (AI Studio → "Get API key"). GOOGLE_API_KEY also works.
GEMINI_API_KEY=

# --- optional ---
# NEUPRINT_SERVER=neuprint.janelia.org
# FLYHYPO_MODEL=gemini-2.5-pro
# FLYHYPO_CACHE_DIR=.flyhypo_cache
